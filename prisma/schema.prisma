// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTICIPANT
  JUDGE
  ORGANIZER
  ADMIN
}

model User {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String         @unique @db.VarChar(255)
  passwordHash String         @map("password_hash")
  fullName     String         @map("full_name") @db.VarChar(255)
  username     String         @unique @db.VarChar(100)
  avatarUrl    String?        @map("avatar_url")
  bio          String?        @db.Text
  githubUrl    String?        @map("github_url")
  linkedinUrl  String?        @map("linkedin_url")
  role         UserRole
  isVerified   Boolean        @default(false) @map("is_verified")
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  lastLoginAt  DateTime?      @map("last_login_at")
  
  // Relations
  refreshTokens   RefreshToken[]
  organizedEvents Event[]
  ledTeams        Team[]         @relation("LedTeams")
  teamMemberships TeamMember[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

enum EventStatus {
  DRAFT
  OPEN
  ACTIVE
  JUDGING
  CLOSED
}

model Event {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug               String      @unique @db.VarChar(100)
  title              String      @db.VarChar(255)
  description        String      @db.Text
  bannerUrl          String?     @map("banner_url")
  organizerId        String      @map("organizer_id") @db.Uuid
  organizer          User        @relation(fields: [organizerId], references: [id])
  status             EventStatus
  maxTeamSize        Int         @default(4) @map("max_team_size")
  minTeamSize        Int         @default(1) @map("min_team_size")
  maxRegistrations   Int?        @map("max_registrations")
  registrationOpen   DateTime    @map("registration_open")
  registrationClose  DateTime    @map("registration_close")
  eventStart         DateTime    @map("event_start")
  eventEnd           DateTime    @map("event_end")
  submissionDeadline DateTime    @map("submission_deadline")
  timezone           String      @default("UTC") @db.VarChar(100)
  prizePool          Json        @map("prize_pool")
  tags               String[]
  isPublic           Boolean     @default(true) @map("is_public")
  isActive           Boolean     @default(true) @map("is_active")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  // Relations
  teams              Team[]

  @@index([tags], type: Gin)
  @@map("events")
}

enum TeamMemberRole {
  LEADER
  MEMBER
}

model Team {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId    String       @map("event_id") @db.Uuid
  event      Event        @relation(fields: [eventId], references: [id])
  name       String       @db.VarChar(100)
  inviteCode String       @unique @map("invite_code") @db.VarChar(12)
  leaderId   String       @map("leader_id") @db.Uuid
  leader     User         @relation("LedTeams", fields: [leaderId], references: [id])
  track      String?      @db.VarChar(100)
  inOpen     Boolean      @default(true) @map("in_open")
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  
  // Relations
  members    TeamMember[]

  @@unique([eventId, name])
  @@map("teams")
}

model TeamMember {
  teamId   String         @map("team_id") @db.Uuid
  team     Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String         @map("user_id") @db.Uuid
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     TeamMemberRole
  joinedAt DateTime       @default(now()) @map("joined_at")

  @@id([teamId, userId])
  @@map("team_members")
}
