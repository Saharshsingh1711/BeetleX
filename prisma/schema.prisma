// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTICIPANT
  JUDGE
  ORGANIZER
  ADMIN
}

model User {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String         @unique @db.VarChar(255)
  passwordHash String         @map("password_hash")
  fullName     String         @map("full_name") @db.VarChar(255)
  username     String         @unique @db.VarChar(100)
  avatarUrl    String?        @map("avatar_url")
  bio          String?        @db.Text
  githubUrl    String?        @map("github_url")
  linkedinUrl  String?        @map("linkedin_url")
  role         UserRole
  isVerified   Boolean        @default(false) @map("is_verified")
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  lastLoginAt  DateTime?      @map("last_login_at")
  
  // Relations
  refreshTokens   RefreshToken[]
  organizedEvents Event[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

enum EventStatus {
  DRAFT
  OPEN
  ACTIVE
  JUDGING
  CLOSED
}

model Event {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug               String      @unique @db.VarChar(100)
  title              String      @db.VarChar(255)
  description        String      @db.Text
  bannerUrl          String?     @map("banner_url")
  organizerId        String      @map("organizer_id") @db.Uuid
  organizer          User        @relation(fields: [organizerId], references: [id])
  status             EventStatus
  maxTeamSize        Int         @default(4) @map("max_team_size")
  minTeamSize        Int         @default(1) @map("min_team_size")
  maxRegistrations   Int?        @map("max_registrations")
  registrationOpen   DateTime    @map("registration_open")
  registrationClose  DateTime    @map("registration_close")
  eventStart         DateTime    @map("event_start")
  eventEnd           DateTime    @map("event_end")
  submissionDeadline DateTime    @map("submission_deadline")
  timezone           String      @default("UTC") @db.VarChar(100)
  prizePool          Json        @map("prize_pool")
  tags               String[]
  isPublic           Boolean     @default(true) @map("is_public")
  isActive           Boolean     @default(true) @map("is_active")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@index([tags], type: Gin)
  @@map("events")
}
